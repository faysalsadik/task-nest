{
  "name": "tasky",
  "version": "1.0.2",
  "description": "Minimal floating todo app",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64"
  },
  "build": {
    "appId": "com.tasky.app",
    "productName": "Tasky",
    "directories": {
      "output": "dist"
    },
    "win": {
      "icon": "icon.ico"
    },
    "files": [
      "index.html",
      "main.js",
      "preload.js",
      "icon.svg",
      "icon.png"
    ]
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1"
  }
}